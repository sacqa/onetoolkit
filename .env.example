# ─── Lovable Cloud / Supabase (auto-populated when you enable Cloud) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
# Service role is server-only; on Lovable Cloud it is injected automatically.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Analytics ───
VITE_GA_ID=G-XXXXXXXXXX

# ─── AdSense (admin panel can also store these in app_settings) ───
VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ─── Tools requiring external APIs (round 2+) ───
REPLICATE_API_KEY=
CONVERT_API_KEY=
EXCHANGE_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
